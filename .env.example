# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=subber

# Server
PORT=8080
BASE_URL=http://localhost:8080
API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Redis
REDIS_ADDR=redis:6379

# Logging
LOG_LEVEL=info
# LOG_FILE=./logs/app.log   # uncomment to enable file output
# RABBITMQ_URL is set by docker/docker-compose.logging.yml when the logging stack is enabled.
